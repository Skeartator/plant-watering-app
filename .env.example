# Clés VAPID pour les notifications push
# Générer avec: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:votre@email.com

# Secret Vercel Cron (générer une chaîne aléatoire)
CRON_SECRET=your_random_secret_here

# Chemin base de données (optionnel, défaut: plants.db à la racine du projet)
# DB_PATH=/tmp/plants.db
